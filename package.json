{
  "name": "karting-timing-backend",
  "version": "3.0.0",
  "description": "Backend API para sistema de cronometraje de karting (ULTRA)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "cross-env RUN_MODE=local TLS_KEY_PATH=C:\\certs\\server.key TLS_CERT_PATH=C:\\certs\\server.crt nodemon server.js",
    "dev:cloud": "cross-env DOTENV_CONFIG_PATH=.env.cloud nodemon -r dotenv/config server.js",
    "start:cloud": "cross-env DOTENV_CONFIG_PATH=.env.cloud node -r dotenv/config server.js"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.11.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.0"
  }
}
